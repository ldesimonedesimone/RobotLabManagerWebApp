# Copy to .env and replace ALL placeholders with values from Neon (Dashboard → Connection string).
# Do not leave the words user, YOUR_NEON_HOST, or dbname as-is — they must be your real credentials and host.

# Read-only Neon (or replica) is fine — used for pilot metrics / operator search.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Writable Postgres for schedule JSON and (later) week-by-week flow persistence. Must allow INSERT/UPDATE/DDL for migrations.
SCHEDULE_DATABASE_URL=postgresql://USER:PASSWORD@ep-yyyy.us-east-1.aws.neon.tech/neondb?sslmode=require
